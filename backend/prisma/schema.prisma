  createdAt                                          DateTime                @default(now())
  AnnouncementAudiences_Announcements_announcementId AnnouncementAudiences[] @relation("Announcements_announcementId")
  Notifications_Announcements_announcementId         Notifications[]         @relation("Announcements_announcementId")
}

model AnnouncementAudiences {
  id             String        @id @default(uuid())
  announcementId String
  announcement   Announcements @relation("Announcements_announcementId", fields: [announcementId], references: [id])
  audienceType   String
  audienceId     String?
  filter         String        @default("{}")
}

model Notifications {
  id                                                  String                   @id @default(uuid())
  recipientUserId                                     String
  recipientUser                                       AppUsers                 @relation("AppUsers_recipientUserId", fields: [recipientUserId], references: [id])
  announcementId                                      String?
  announcement                                        Announcements?           @relation("Announcements_announcementId", fields: [announcementId], references: [id])
  eventKey                                            String?
  title                                               String
  safeSummary                                         String?
  category                                            String?
  priority                                            String                   @default("info")
  sourceModule                                        String?
  sourceTable                                         String?
  sourceId                                            String?
  readAt                                              DateTime?
  acknowledgedAt                                      DateTime?
  archivedAt                                          DateTime?
  createdAt                                           DateTime                 @default(now())
  NotificationDeliveries_Notifications_notificationId NotificationDeliveries[] @relation("Notifications_notificationId")
}

model NotificationDeliveries {
  id                String        @id @default(uuid())
  notificationId    String
  notification      Notifications @relation("Notifications_notificationId", fields: [notificationId], references: [id])
  channel           String
  deliveryStatus    String        @default("pending")
  providerReference String?
  attemptedAt       DateTime?
  deliveredAt       DateTime?
  failureReason     String?
}

model NotificationPreferences {
  id        String   @id @default(uuid())
  userId    String
  user      AppUsers @relation("AppUsers_userId", fields: [userId], references: [id])
  category  String
  channel   String
  enabled   Boolean
  updatedAt DateTime @default(now())

  @@unique([userId, category, channel])
}

model ArticleCategories {
  id                                           String              @id @default(uuid())
  parentId                                     String?
  parent                                       ArticleCategories?  @relation("ArticleCategories_parentId", fields: [parentId], references: [id])
  name                                         String
  slug                                         String              @unique
  status                                       String              @default("active")
  ArticleCategories_ArticleCategories_parentId ArticleCategories[] @relation("ArticleCategories_parentId")
  Articles_ArticleCategories_categoryId        Articles[]          @relation("ArticleCategories_categoryId")
}

model Articles {
  id                                     String                @id @default(uuid())
  categoryId                             String?
  category                               ArticleCategories?    @relation("ArticleCategories_categoryId", fields: [categoryId], references: [id])
  agencyId                               String?
  agency                                 TravelAgencies?       @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  title                                  String
  slug                                   String                @unique
  body                                   String
  status                                 String                @default("draft")
  visibility                             String                @default("public")
  sourceLabel                            String?
  reviewerLabel                          String?
  disclaimer                             String?
  publishedAt                            DateTime?
  createdByUserId                        String?
  createdByUser                          AppUsers?             @relation("AppUsers_createdByUserId", fields: [createdByUserId], references: [id])
  createdAt                              DateTime              @default(now())
  updatedAt                              DateTime              @default(now())
  ArticleContextLinks_Articles_articleId ArticleContextLinks[] @relation("Articles_articleId")
}

model ArticleContextLinks {
  id          String   @id @default(uuid())
  articleId   String
  article     Articles @relation("Articles_articleId", fields: [articleId], references: [id])
  contextType String
  contextId   String?
  sortOrder   Int      @default(0)
}

model Testimonials {
  id           String            @id @default(uuid())
  authorUserId String?
  authorUser   AppUsers?         @relation("AppUsers_authorUserId", fields: [authorUserId], references: [id])
  agencyId     String?
  agency       TravelAgencies?   @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  packageId    String?
  package      Packages?         @relation("Packages_packageId", fields: [packageId], references: [id])
  bookingId    String?
  booking      Bookings?         @relation("Bookings_bookingId", fields: [bookingId], references: [id])
  groupTripId  String?
  groupTrip    GroupTrips?       @relation("GroupTrips_groupTripId", fields: [groupTripId], references: [id])
  mutawwifId   String?
  mutawwif     MutawwifProfiles? @relation("MutawwifProfiles_mutawwifId", fields: [mutawwifId], references: [id])
  rating       Float?
  title        String?
  body         String?
  status       String            @default("pending_review")
  visibility   String            @default("private")
  createdAt    DateTime          @default(now())
  publishedAt  DateTime?
}

model Ratings {
  id           String    @id @default(uuid())
  authorUserId String?
  authorUser   AppUsers? @relation("AppUsers_authorUserId", fields: [authorUserId], references: [id])
  targetType   String
  targetId     String
  rating       Float
  feedback     String?
  status       String    @default("submitted")
  createdAt    DateTime  @default(now())
}

model SavedPackages {
  id        String   @id @default(uuid())
  userId    String
  user      AppUsers @relation("AppUsers_userId", fields: [userId], references: [id])
  packageId String
  package   Packages @relation("Packages_packageId", fields: [packageId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, packageId])
}

model CompareSessions {
  id                                                   String                @id @default(uuid())
  userId                                               String?
  user                                                 AppUsers?             @relation("AppUsers_userId", fields: [userId], references: [id])
  sessionKey                                           String?
  createdAt                                            DateTime              @default(now())
  updatedAt                                            DateTime              @default(now())
  CompareSessionItems_CompareSessions_compareSessionId CompareSessionItems[] @relation("CompareSessions_compareSessionId")
}

model CompareSessionItems {
  id               String          @id @default(uuid())
  compareSessionId String
  compareSession   CompareSessions @relation("CompareSessions_compareSessionId", fields: [compareSessionId], references: [id])
  packageId        String
  package          Packages        @relation("Packages_packageId", fields: [packageId], references: [id])
  sortOrder        Int             @default(0)

  @@unique([compareSessionId, packageId])
}
