generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppUsers {
  id                                               String                       @id @default(uuid())
  authUserId                                       String?                      @unique
  displayName                                      String?
  email                                            String?
  phone                                            String?
  avatarFileId                                     String?
  accountStatus                                    String                       @default("active")
  preferredLanguage                                String                       @default("en")
  timezone                                         String                       @default("Asia/Kuala_Lumpur")
  createdAt                                        DateTime                     @default(now())
  updatedAt                                        DateTime                     @default(now())
  deletedAt                                        DateTime?
  StoredFiles_AppUsers_ownerUserId                 StoredFiles[]                @relation("AppUsers_ownerUserId")
  FileAccessLogs_AppUsers_actorUserId              FileAccessLogs[]             @relation("AppUsers_actorUserId")
  AuditLogs_AppUsers_actorUserId                   AuditLogs[]                  @relation("AppUsers_actorUserId")
  PortalMemberships_AppUsers_userId                PortalMemberships[]          @relation("AppUsers_userId")
  PortalMemberships_AppUsers_invitedByUserId       PortalMemberships[]          @relation("AppUsers_invitedByUserId")
  AdminStaffProfiles_AppUsers_userId               AdminStaffProfiles[]         @relation("AppUsers_userId")
  TravelAgencyStaff_AppUsers_userId                TravelAgencyStaff[]          @relation("AppUsers_userId")
  UserSessions_AppUsers_userId                     UserSessions[]               @relation("AppUsers_userId")
  TravelAgencyDocuments_AppUsers_reviewedByUserId  TravelAgencyDocuments[]      @relation("AppUsers_reviewedByUserId")
  PlatformSettings_AppUsers_updatedByUserId        PlatformSettings[]           @relation("AppUsers_updatedByUserId")
  AgencySettings_AppUsers_updatedByUserId          AgencySettings[]             @relation("AppUsers_updatedByUserId")
  PilgrimProfiles_AppUsers_userId                  PilgrimProfiles[]            @relation("AppUsers_userId")
  MutawwifProfiles_AppUsers_userId                 MutawwifProfiles[]           @relation("AppUsers_userId")
  MutawwifDocuments_AppUsers_reviewedByUserId      MutawwifDocuments[]          @relation("AppUsers_reviewedByUserId")
  Packages_AppUsers_createdByUserId                Packages[]                   @relation("AppUsers_createdByUserId")
  PackageVersions_AppUsers_createdByUserId         PackageVersions[]            @relation("AppUsers_createdByUserId")
  Bookings_AppUsers_createdByUserId                Bookings[]                   @relation("AppUsers_createdByUserId")
  BookingCancellations_AppUsers_requestedByUserId  BookingCancellations[]       @relation("AppUsers_requestedByUserId")
  Invoices_AppUsers_createdByUserId                Invoices[]                   @relation("AppUsers_createdByUserId")
  Payments_AppUsers_recordedByUserId               Payments[]                   @relation("AppUsers_recordedByUserId")
  Payments_AppUsers_verifiedByUserId               Payments[]                   @relation("AppUsers_verifiedByUserId")
  Refunds_AppUsers_requestedByUserId               Refunds[]                    @relation("AppUsers_requestedByUserId")
  Refunds_AppUsers_approvedByUserId                Refunds[]                    @relation("AppUsers_approvedByUserId")
  FinanceLedgerEntries_AppUsers_userId             FinanceLedgerEntries[]       @relation("AppUsers_userId")
  SettlementBatches_AppUsers_preparedByUserId      SettlementBatches[]          @relation("AppUsers_preparedByUserId")
  GroupTrips_AppUsers_createdByUserId              GroupTrips[]                 @relation("AppUsers_createdByUserId")
  TripChangeAcknowledgements_AppUsers_userId       TripChangeAcknowledgements[] @relation("AppUsers_userId")
  MutawwifAssignments_AppUsers_createdByUserId     MutawwifAssignments[]        @relation("AppUsers_createdByUserId")
  PilgrimDocuments_AppUsers_uploadedByUserId       PilgrimDocuments[]           @relation("AppUsers_uploadedByUserId")
  PilgrimDocuments_AppUsers_reviewedByUserId       PilgrimDocuments[]           @relation("AppUsers_reviewedByUserId")
  ReadinessItems_AppUsers_updatedByUserId          ReadinessItems[]             @relation("AppUsers_updatedByUserId")
  ReadinessItemEvents_AppUsers_actorUserId         ReadinessItemEvents[]        @relation("AppUsers_actorUserId")
  ReferralCodes_AppUsers_ownerUserId               ReferralCodes[]              @relation("AppUsers_ownerUserId")
  ReferralAttributions_AppUsers_referredUserId     ReferralAttributions[]       @relation("AppUsers_referredUserId")
  ReferralRewards_AppUsers_beneficiaryUserId       ReferralRewards[]            @relation("AppUsers_beneficiaryUserId")
  PayoutDestinations_AppUsers_userId               PayoutDestinations[]         @relation("AppUsers_userId")
  WithdrawalRequests_AppUsers_userId               WithdrawalRequests[]         @relation("AppUsers_userId")
  SupportCases_AppUsers_createdByUserId            SupportCases[]               @relation("AppUsers_createdByUserId")
  SupportCases_AppUsers_assignedAgencyPicUserId    SupportCases[]               @relation("AppUsers_assignedAgencyPicUserId")
  SupportCaseComments_AppUsers_authorUserId        SupportCaseComments[]        @relation("AppUsers_authorUserId")
  SupportCaseAttachments_AppUsers_uploadedByUserId SupportCaseAttachments[]     @relation("AppUsers_uploadedByUserId")
  Announcements_AppUsers_createdByUserId           Announcements[]              @relation("AppUsers_createdByUserId")
  Notifications_AppUsers_recipientUserId           Notifications[]              @relation("AppUsers_recipientUserId")
  NotificationPreferences_AppUsers_userId          NotificationPreferences[]    @relation("AppUsers_userId")
  Articles_AppUsers_createdByUserId                Articles[]                   @relation("AppUsers_createdByUserId")
  Testimonials_AppUsers_authorUserId               Testimonials[]               @relation("AppUsers_authorUserId")
  Ratings_AppUsers_authorUserId                    Ratings[]                    @relation("AppUsers_authorUserId")
  SavedPackages_AppUsers_userId                    SavedPackages[]              @relation("AppUsers_userId")
  CompareSessions_AppUsers_userId                  CompareSessions[]            @relation("AppUsers_userId")
}

model StoredFiles {
  id                                                           String                            @id @default(uuid())
  bucket                                                       String
  objectPath                                                   String
  originalFilename                                             String?
  mimeType                                                     String?
  fileSizeBytes                                                Int?
  checksum                                                     String?
  visibility                                                   String                            @default("restricted")
  ownerUserId                                                  String?
  ownerUser                                                    AppUsers?                         @relation("AppUsers_ownerUserId", fields: [ownerUserId], references: [id])
  agencyId                                                     String?
  moduleName                                                   String?
  entityTable                                                  String?
  entityId                                                     String?
  scanStatus                                                   String                            @default("pending")
  createdAt                                                    DateTime                          @default(now())
  deletedAt                                                    DateTime?
  FileAccessLogs_StoredFiles_fileId                            FileAccessLogs[]                  @relation("StoredFiles_fileId")
  TravelAgencies_StoredFiles_logoFileId                        TravelAgencies[]                  @relation("StoredFiles_logoFileId")
  TravelAgencyDocuments_StoredFiles_fileId                     TravelAgencyDocuments[]           @relation("StoredFiles_fileId")
  MutawwifProfiles_StoredFiles_profilePhotoFileId              MutawwifProfiles[]                @relation("StoredFiles_profilePhotoFileId")
  MutawwifDocuments_StoredFiles_fileId                         MutawwifDocuments[]               @relation("StoredFiles_fileId")
  Airlines_StoredFiles_logoFileId                              Airlines[]                        @relation("StoredFiles_logoFileId")
  Hotels_StoredFiles_imageFileId                               Hotels[]                          @relation("StoredFiles_imageFileId")
  Packages_StoredFiles_thumbnailFileId                         Packages[]                        @relation("StoredFiles_thumbnailFileId")
  PackageMedia_StoredFiles_fileId                              PackageMedia[]                    @relation("StoredFiles_fileId")
  Payments_StoredFiles_proofFileId                             Payments[]                        @relation("StoredFiles_proofFileId")
  MutawwifAssignmentHandoverNotes_StoredFiles_attachmentFileId MutawwifAssignmentHandoverNotes[] @relation("StoredFiles_attachmentFileId")
  PilgrimDocuments_StoredFiles_fileId                          PilgrimDocuments[]                @relation("StoredFiles_fileId")
  SupportCaseAttachments_StoredFiles_fileId                    SupportCaseAttachments[]          @relation("StoredFiles_fileId")
  AdminStaffProfiles_StoredFiles_AdminProfilePhoto             AdminStaffProfiles[]              @relation("StoredFiles_AdminProfilePhoto")
  TravelAgencyStaff_StoredFiles_TAStaffProfilePhoto            TravelAgencyStaff[]               @relation("StoredFiles_TAStaffProfilePhoto")
  PilgrimProfiles_StoredFiles_PilgrimProfilePhoto              PilgrimProfiles[]                 @relation("StoredFiles_PilgrimProfilePhoto")

  @@unique([bucket, objectPath])
}

model FileAccessLogs {
  id          String      @id @default(uuid())
  fileId      String
  file        StoredFiles @relation("StoredFiles_fileId", fields: [fileId], references: [id])
  actorUserId String?
  actorUser   AppUsers?   @relation("AppUsers_actorUserId", fields: [actorUserId], references: [id])
  action      String
  reason      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
}

model AuditLogs {
  id          String    @id @default(uuid())
  actorUserId String?
  actorUser   AppUsers? @relation("AppUsers_actorUserId", fields: [actorUserId], references: [id])
  actorPortal String?
  agencyId    String?
  action      String
  entityTable String
  entityId    String?
  oldValues   String?
  newValues   String?
  reason      String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
}

model EventOutbox {
  id             String    @id @default(uuid())
  eventKey       String
  aggregateTable String?
  aggregateId    String?
  payload        String    @default("{}")
  status         String    @default("pending")
  attempts       Int       @default(0)
  scheduledAt    DateTime?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
}

model TravelAgencies {
  id                                               String                     @id @default(uuid())
  legalName                                        String
  publicDisplayName                                String?
  registrationNumber                               String?
  travelLicenseNumber                              String?
  licenseExpiryDate                                DateTime?
  agencyType                                       String?
  countryCode                                      String?
  city                                             String?
  email                                            String?
  websiteUrl                                       String?
  description                                      String?
  logoFileId                                       String?
  logoFile                                         StoredFiles?               @relation("StoredFiles_logoFileId", fields: [logoFileId], references: [id])
  verificationStatus                               String                     @default("pending_review")
  publicProfileStatus                              String                     @default("hidden")
  status                                           String                     @default("active")
  createdAt                                        DateTime                   @default(now())
  updatedAt                                        DateTime                   @default(now())
  deletedAt                                        DateTime?
  PermissionGroups_TravelAgencies_agencyId         PermissionGroups[]         @relation("TravelAgencies_agencyId")
  PortalMemberships_TravelAgencies_agencyId        PortalMemberships[]        @relation("TravelAgencies_agencyId")
  TravelAgencyStaff_TravelAgencies_agencyId        TravelAgencyStaff[]        @relation("TravelAgencies_agencyId")
  TravelAgencyDocuments_TravelAgencies_agencyId    TravelAgencyDocuments[]    @relation("TravelAgencies_agencyId")
  TravelAgencyBankAccounts_TravelAgencies_agencyId TravelAgencyBankAccounts[] @relation("TravelAgencies_agencyId")
  AgencySettings_TravelAgencies_agencyId           AgencySettings[]           @relation("TravelAgencies_agencyId")
  PilgrimProfiles_TravelAgencies_createdByAgencyId PilgrimProfiles[]          @relation("TravelAgencies_createdByAgencyId")
  PilgrimAgencyLinks_TravelAgencies_agencyId       PilgrimAgencyLinks[]       @relation("TravelAgencies_agencyId")
  PilgrimFamilyGroups_TravelAgencies_agencyId      PilgrimFamilyGroups[]      @relation("TravelAgencies_agencyId")
  ItineraryTemplates_TravelAgencies_agencyId       ItineraryTemplates[]       @relation("TravelAgencies_agencyId")
  Packages_TravelAgencies_agencyId                 Packages[]                 @relation("TravelAgencies_agencyId")
  Bookings_TravelAgencies_agencyId                 Bookings[]                 @relation("TravelAgencies_agencyId")
  Invoices_TravelAgencies_agencyId                 Invoices[]                 @relation("TravelAgencies_agencyId")
  Payments_TravelAgencies_agencyId                 Payments[]                 @relation("TravelAgencies_agencyId")
  Refunds_TravelAgencies_agencyId                  Refunds[]                  @relation("TravelAgencies_agencyId")
  FinanceLedgerEntries_TravelAgencies_agencyId     FinanceLedgerEntries[]     @relation("TravelAgencies_agencyId")
  CommissionRecords_TravelAgencies_agencyId        CommissionRecords[]        @relation("TravelAgencies_agencyId")
  SettlementBatches_TravelAgencies_agencyId        SettlementBatches[]        @relation("TravelAgencies_agencyId")
  GroupTrips_TravelAgencies_agencyId               GroupTrips[]               @relation("TravelAgencies_agencyId")
  MutawwifAssignments_TravelAgencies_agencyId      MutawwifAssignments[]      @relation("TravelAgencies_agencyId")
  PilgrimDocuments_TravelAgencies_agencyId         PilgrimDocuments[]         @relation("TravelAgencies_agencyId")
  DocumentRequirements_TravelAgencies_agencyId     DocumentRequirements[]     @relation("TravelAgencies_agencyId")
  ServiceRequirements_TravelAgencies_agencyId      ServiceRequirements[]      @relation("TravelAgencies_agencyId")
  ReadinessItems_TravelAgencies_agencyId           ReadinessItems[]           @relation("TravelAgencies_agencyId")
  ReferralPrograms_TravelAgencies_agencyId         ReferralPrograms[]         @relation("TravelAgencies_agencyId")
  AllowanceRecords_TravelAgencies_agencyId         AllowanceRecords[]         @relation("TravelAgencies_agencyId")
  SupportCases_TravelAgencies_agencyId             SupportCases[]             @relation("TravelAgencies_agencyId")
  Announcements_TravelAgencies_agencyId            Announcements[]            @relation("TravelAgencies_agencyId")
  Articles_TravelAgencies_agencyId                 Articles[]                 @relation("TravelAgencies_agencyId")
  Testimonials_TravelAgencies_agencyId             Testimonials[]             @relation("TravelAgencies_agencyId")
}

model PermissionGroups {
  id                                                      String                 @id @default(uuid())
  agencyId                                                String?
  agency                                                  TravelAgencies?        @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  portal                                                  String
  name                                                    String
  description                                             String?
  isSystem                                                Boolean
  status                                                  String                 @default("active")
  createdAt                                               DateTime               @default(now())
  updatedAt                                               DateTime               @default(now())
  PermissionGroupRules_PermissionGroups_permissionGroupId PermissionGroupRules[] @relation("PermissionGroups_permissionGroupId")
  PortalMemberships_PermissionGroups_permissionGroupId    PortalMemberships[]    @relation("PermissionGroups_permissionGroupId")
  TravelAgencyStaff_PermissionGroups_permissionGroupId    TravelAgencyStaff[]    @relation("PermissionGroups_permissionGroupId")

  @@unique([agencyId, portal, name])
}

model PermissionGroupRules {
  id                String           @id @default(uuid())
  permissionGroupId String
  permissionGroup   PermissionGroups @relation("PermissionGroups_permissionGroupId", fields: [permissionGroupId], references: [id])
  moduleKey         String
  actionKey         String
  sensitiveKey      String?
  allowed           Boolean
  createdAt         DateTime         @default(now())
}

model PortalMemberships {
  id                String            @id @default(uuid())
  userId            String
  user              AppUsers          @relation("AppUsers_userId", fields: [userId], references: [id])
  portal            String
  agencyId          String?
  agency            TravelAgencies?   @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  permissionGroupId String?
  permissionGroup   PermissionGroups? @relation("PermissionGroups_permissionGroupId", fields: [permissionGroupId], references: [id])
  roleKey           String
  status            String            @default("active")
  invitedByUserId   String?
  invitedByUser     AppUsers?         @relation("AppUsers_invitedByUserId", fields: [invitedByUserId], references: [id])
  acceptedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now())

  @@unique([userId, portal, agencyId])
}

model AdminStaffProfiles {
  id                 String       @id @default(uuid())
  userId             String       @unique
  user               AppUsers     @relation("AppUsers_userId", fields: [userId], references: [id])
  staffCode          String?
  department         String?
  title              String?
  email              String?
  profilePhotoFileId String?
  profilePhotoFile   StoredFiles? @relation("StoredFiles_AdminProfilePhoto", fields: [profilePhotoFileId], references: [id])
  verificationStatus String       @default("pending")
  status             String       @default("active")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now())
}

model TravelAgencyStaff {
  id                 String            @id @default(uuid())
  agencyId           String
  agency             TravelAgencies    @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  userId             String?
  user               AppUsers?         @relation("AppUsers_userId", fields: [userId], references: [id])
  staffName          String
  email              String
  phone              String?
  roleTemplate       String
  profilePhotoFileId String?
  profilePhotoFile   StoredFiles?      @relation("StoredFiles_TAStaffProfilePhoto", fields: [profilePhotoFileId], references: [id])
  permissionGroupId  String?
  permissionGroup    PermissionGroups? @relation("PermissionGroups_permissionGroupId", fields: [permissionGroupId], references: [id])
  verificationStatus String            @default("pending")
  invitationStatus   String            @default("draft")
  status             String            @default("draft")
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now())

  @@unique([agencyId, email])
}

model UserSessions {
  id            String    @id @default(uuid())
  userId        String
  user          AppUsers  @relation("AppUsers_userId", fields: [userId], references: [id])
  sessionStatus String    @default("active")
  deviceLabel   String?
  ipAddress     String?
  userAgent     String?
  lastSeenAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
}

model TravelAgencyDocuments {
  id               String         @id @default(uuid())
  agencyId         String
  agency           TravelAgencies @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  documentType     String
  fileId           String?
  file             StoredFiles?   @relation("StoredFiles_fileId", fields: [fileId], references: [id])
  status           String         @default("pending_review")
  expiryDate       DateTime?
  adminRemark      String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   AppUsers?      @relation("AppUsers_reviewedByUserId", fields: [reviewedByUserId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now())
}

model TravelAgencyBankAccounts {
  id                     String         @id @default(uuid())
  agencyId               String
  agency                 TravelAgencies @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  bankName               String
  accountHolderName      String
  accountNumberEncrypted String?
  accountNumberLast4     String?
  status                 String         @default("pending_review")
  isPrimary              Boolean
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @default(now())
}

model PlatformSettings {
  id              String    @id @default(uuid())
  settingKey      String    @unique
  settingValue    String
  ownership       String    @default("platform")
  isSensitive     Boolean
  updatedByUserId String?
  updatedByUser   AppUsers? @relation("AppUsers_updatedByUserId", fields: [updatedByUserId], references: [id])
  updatedAt       DateTime  @default(now())
}

model AgencySettings {
  id              String         @id @default(uuid())
  agencyId        String
  agency          TravelAgencies @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  settingKey      String
  settingValue    String
  ownership       String         @default("agency")
  updatedByUserId String?
  updatedByUser   AppUsers?      @relation("AppUsers_updatedByUserId", fields: [updatedByUserId], references: [id])
  updatedAt       DateTime       @default(now())

  @@unique([agencyId, settingKey])
}

model PilgrimProfiles {
  id                                                   String                 @id @default(uuid())
  userId                                               String?
  user                                                 AppUsers?              @relation("AppUsers_userId", fields: [userId], references: [id])
  fullName                                             String
  displayName                                          String?
  email                                                String?
  phone                                                String?
  gender                                               String?
  dateOfBirth                                          DateTime?
  nationalityCode                                      String?
  identityNumberEncrypted                              String?
  identityNumberLast4                                  String?
  passportNumberEncrypted                              String?
  passportNumberLast4                                  String?
  passportExpiryDate                                   DateTime?
  address                                              String?
  emergencyContact                                     String?
  profilePhotoFileId                                   String?
  profilePhotoFile                                     StoredFiles?           @relation("StoredFiles_PilgrimProfilePhoto", fields: [profilePhotoFileId], references: [id])
  profileStatus                                        String                 @default("pending_profile")
  verificationStatus                                   String                 @default("pending")
  createdByAgencyId                                    String?
  createdByAgency                                      TravelAgencies?        @relation("TravelAgencies_createdByAgencyId", fields: [createdByAgencyId], references: [id])
  createdAt                                            DateTime               @default(now())
  updatedAt                                            DateTime               @default(now())
  deletedAt                                            DateTime?
  PilgrimAgencyLinks_PilgrimProfiles_pilgrimId         PilgrimAgencyLinks[]   @relation("PilgrimProfiles_pilgrimId")
  PilgrimFamilyGroups_PilgrimProfiles_primaryPilgrimId PilgrimFamilyGroups[]  @relation("PilgrimProfiles_primaryPilgrimId")
  PilgrimFamilyMembers_PilgrimProfiles_pilgrimId       PilgrimFamilyMembers[] @relation("PilgrimProfiles_pilgrimId")
  Bookings_PilgrimProfiles_primaryPilgrimId            Bookings[]             @relation("PilgrimProfiles_primaryPilgrimId")
  BookingParticipants_PilgrimProfiles_pilgrimId        BookingParticipants[]  @relation("PilgrimProfiles_pilgrimId")
  Invoices_PilgrimProfiles_pilgrimId                   Invoices[]             @relation("PilgrimProfiles_pilgrimId")
  TripMembers_PilgrimProfiles_pilgrimId                TripMembers[]          @relation("PilgrimProfiles_pilgrimId")
  PilgrimDocuments_PilgrimProfiles_pilgrimId           PilgrimDocuments[]     @relation("PilgrimProfiles_pilgrimId")
  ReadinessItems_PilgrimProfiles_pilgrimId             ReadinessItems[]       @relation("PilgrimProfiles_pilgrimId")
}

model PilgrimAgencyLinks {
  id         String          @id @default(uuid())
  pilgrimId  String
  pilgrim    PilgrimProfiles @relation("PilgrimProfiles_pilgrimId", fields: [pilgrimId], references: [id])
  agencyId   String
  agency     TravelAgencies  @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  linkSource String
  status     String          @default("active")
  createdAt  DateTime        @default(now())

  @@unique([pilgrimId, agencyId])
}

model PilgrimFamilyGroups {
  id                                                     String                 @id @default(uuid())
  agencyId                                               String?
  agency                                                 TravelAgencies?        @relation("TravelAgencies_agencyId", fields: [agencyId], references: [id])
  groupName                                              String
  primaryPilgrimId                                       String?
  primaryPilgrim                                         PilgrimProfiles?       @relation("PilgrimProfiles_primaryPilgrimId", fields: [primaryPilgrimId], references: [id])
  notes                                                  String?
  createdAt                                              DateTime               @default(now())
  PilgrimFamilyMembers_PilgrimFamilyGroups_familyGroupId PilgrimFamilyMembers[] @relation("PilgrimFamilyGroups_familyGroupId")
  BookingParticipants_PilgrimFamilyGroups_familyGroupId  BookingParticipants[]  @relation("PilgrimFamilyGroups_familyGroupId")
}

model PilgrimFamilyMembers {
  id               String              @id @default(uuid())
  familyGroupId    String
  familyGroup      PilgrimFamilyGroups @relation("PilgrimFamilyGroups_familyGroupId", fields: [familyGroupId], references: [id])
  pilgrimId        String
  pilgrim          PilgrimProfiles     @relation("PilgrimProfiles_pilgrimId", fields: [pilgrimId], references: [id])
  relationship     String?
  isPrimaryContact Boolean
  createdAt        DateTime            @default(now())

  @@unique([familyGroupId, pilgrimId])
}

model MutawwifProfiles {
  id                                                              String                            @id @default(uuid())
  userId                                                          String                            @unique
  user                                                            AppUsers                          @relation("AppUsers_userId", fields: [userId], references: [id])
  fullName                                                        String
  displayName                                                     String?
  title                                                           String?
  phone                                                           String?
  email                                                           String?
  nationalityCode                                                 String?
  identityNumberEncrypted                                         String?
  identityNumberLast4                                             String?
  passportNumberEncrypted                                         String?
  passportNumberLast4                                             String?
  profilePhotoFileId                                              String?
  profilePhotoFile                                                StoredFiles?                      @relation("StoredFiles_profilePhotoFileId", fields: [profilePhotoFileId], references: [id])
  verificationStatus                                              String                            @default("pending_review")
  profileCompletionStatus                                         String                            @default("incomplete")
  assignmentReadinessStatus                                       String                            @default("not_ready")
  availabilityStatus                                              String                            @default("available")
  publicVisibilityStatus                                          String                            @default("private")
  createdAt                                                       DateTime                          @default(now())
  updatedAt                                                       DateTime                          @default(now())
  deletedAt                                                       DateTime?
  MutawwifDocuments_MutawwifProfiles_mutawwifId                   MutawwifDocuments[]               @relation("MutawwifProfiles_mutawwifId")
  MutawwifLanguages_MutawwifProfiles_mutawwifId                   MutawwifLanguages[]               @relation("MutawwifProfiles_mutawwifId")
  MutawwifSpecializations_MutawwifProfiles_mutawwifId             MutawwifSpecializations[]         @relation("MutawwifProfiles_mutawwifId")
  MutawwifAvailability_MutawwifProfiles_mutawwifId                MutawwifAvailability[]            @relation("MutawwifProfiles_mutawwifId")
  MutawwifAssignmentPreferences_MutawwifProfiles_mutawwifId       MutawwifAssignmentPreferences[]   @relation("MutawwifProfiles_mutawwifId")
  MutawwifAssignments_MutawwifProfiles_mutawwifId                 MutawwifAssignments[]             @relation("MutawwifProfiles_mutawwifId")
  MutawwifAssignmentRequests_MutawwifProfiles_mutawwifId          MutawwifAssignmentRequests[]      @relation("MutawwifProfiles_mutawwifId")
